# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Resend API key — sign up at https://resend.com (free tier: 3,000 emails/month)
# After signup: verify campexplorer.sa domain (one DNS record), then create an API key.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email destination for new registration submissions
REGISTRATION_TO_EMAIL=info@campexplorer.sa

# Email "from" address — must be on the verified Resend domain
REGISTRATION_FROM_EMAIL=Camp Explorer <noreply@campexplorer.sa>

# Google Apps Script Web App URL for appending to Google Sheets
# See: docs/google-sheets-setup.md (to be added)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/xxxxxxxxxxxxxxxxxxxx/exec
